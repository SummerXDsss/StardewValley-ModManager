<Window
    x:Class="ValleySteward.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

  <Grid x:Name="RootGrid"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        AllowDrop="True"
        DragOver="OnRootDragOver"
        Drop="OnRootDrop"
        Loaded="OnRootLoaded">
    <Grid.Resources>
      <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="8,4" />
      </Style>
    </Grid.Resources>

    <Grid.RowDefinitions>
      <RowDefinition x:Name="TitleBarRow" Height="48" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
      <Grid x:Name="AppTitleBar" Height="48">
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="LeftInsetColumn" Width="0" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition x:Name="RightInsetColumn" Width="138" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1"
                    Margin="12,0,10,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
          <FontIcon FontSize="16" Glyph="&#xE8A1;" />
          <TextBlock x:Name="BrandText"
                     VerticalAlignment="Center"
                     FontFamily="Segoe UI Variable Display"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Text="Valley Steward" />
        </StackPanel>

        <Button x:Name="PathButton"
                Grid.Column="2"
                Margin="0,7,4,7"
                Click="OnPathClick"
                Style="{StaticResource TitleBarButtonStyle}"
                AutomationProperties.Name="查看或修改游戏路径">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon FontSize="14" Glyph="&#xE8B7;" />
            <TextBlock x:Name="PathLabel" VerticalAlignment="Center" Text="未设置" />
          </StackPanel>
        </Button>

        <Button x:Name="SteamButton"
                Grid.Column="3"
                Margin="0,7,4,7"
                Style="{StaticResource TitleBarButtonStyle}"
                AutomationProperties.Name="查看 Steam 状态">
          <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft">
              <Grid Width="390" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="64" MinWidth="64" MaxWidth="64" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="64" Height="64"
                        VerticalAlignment="Top"
                        CornerRadius="6"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                  <Grid>
                    <FontIcon FontSize="30"
                              Glyph="&#xE77B;"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Image x:Name="SteamAvatarImage"
                           Width="62" Height="62"
                           Stretch="UniformToFill"
                           ImageFailed="OnSteamAvatarImageFailed"
                           AutomationProperties.Name="Steam 本机缓存头像" />
                  </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="12">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse x:Name="SteamFlyoutDot" Width="8" Height="8" VerticalAlignment="Center" />
                    <TextBlock x:Name="SteamFlyoutTitle"
                               MaxWidth="280"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <Grid RowSpacing="8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="76" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="账号" />
                    <TextBlock x:Name="SteamAccountText" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="SteamID64" />
                    <TextBlock x:Name="SteamIdText" Grid.Row="1" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Row="1" Grid.Column="2" Padding="6,2" Click="OnCopySteamId" ToolTipService.ToolTip="复制 SteamID64">
                      <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                    </Button>
                    <TextBlock Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="好友码" />
                    <TextBlock x:Name="FriendCodeText" Grid.Row="2" Grid.Column="1" />
                    <Button Grid.Row="2" Grid.Column="2" Padding="6,2" Click="OnCopyFriendCode" ToolTipService.ToolTip="复制好友码">
                      <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                    </Button>
                    <TextBlock Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="来源" />
                    <TextBlock x:Name="SteamSourceText" Grid.Row="3" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                  </Grid>
                </StackPanel>
              </Grid>
            </Flyout>
          </Button.Flyout>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Ellipse x:Name="SteamStatusDot" Width="7" Height="7" VerticalAlignment="Center" />
            <TextBlock x:Name="SteamLabel" VerticalAlignment="Center" Text="Steam" />
          </StackPanel>
        </Button>

        <Button x:Name="SmapiButton"
                Grid.Column="4"
                Margin="0,7,4,7"
                Click="OnSmapiClick"
                Style="{StaticResource TitleBarButtonStyle}"
                AutomationProperties.Name="查看 SMAPI 状态">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon FontSize="14" Glyph="&#xE72E;" />
            <TextBlock x:Name="SmapiLabel" VerticalAlignment="Center" Text="SMAPI" />
          </StackPanel>
        </Button>

        <Grid x:Name="DragRegion" Grid.Column="5" MinWidth="24" Background="Transparent" />

        <Border x:Name="ProcessBadge"
                Grid.Column="6"
                Margin="6,8,6,8"
                Padding="8,3"
                CornerRadius="4"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Ellipse x:Name="ProcessStatusDot" Width="7" Height="7" VerticalAlignment="Center" />
            <TextBlock x:Name="ProcessStatusLabel" VerticalAlignment="Center" Text="未运行" />
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="7"
                    Margin="0,7,4,7"
                    Orientation="Horizontal"
                    Spacing="4">
          <SplitButton x:Name="LaunchButton"
                       MinWidth="126"
                       Click="OnLaunchPreferredClick">
            <SplitButton.Content>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon FontSize="14" Glyph="&#xE768;" />
                <TextBlock x:Name="LaunchButtonLabel" VerticalAlignment="Center" Text="启动游戏" />
              </StackPanel>
            </SplitButton.Content>
            <SplitButton.Flyout>
              <MenuFlyout>
                <MenuFlyoutItem Text="使用 SMAPI 启动" Click="OnLaunchSmapiClick">
                  <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE768;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="启动原版游戏" Click="OnLaunchVanillaClick">
                  <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7FC;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="多人 Mod 配置" Click="OnLaunchProfileClick">
                  <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE716;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="RememberLaunchItem"
                                      Text="记住上次选择"
                                      Click="OnRememberLaunchClick" />
              </MenuFlyout>
            </SplitButton.Flyout>
          </SplitButton>
          <Button x:Name="StopButton"
                  Visibility="Collapsed"
                  Click="OnStopClick"
                  Style="{StaticResource TitleBarButtonStyle}"
                  ToolTipService.ToolTip="关闭游戏">
            <FontIcon Glyph="&#xE71A;" />
          </Button>
          <Button x:Name="RestartButton"
                  Visibility="Collapsed"
                  Click="OnRestartClick"
                  Style="{StaticResource TitleBarButtonStyle}"
                  ToolTipService.ToolTip="重新启动">
            <FontIcon Glyph="&#xE72C;" />
          </Button>
        </StackPanel>

        <Button x:Name="ThemeButton"
                Grid.Column="8"
                Margin="0,7,4,7"
                Click="OnThemeClick"
                Style="{StaticResource TitleBarButtonStyle}"
                ToolTipService.ToolTip="切换主题">
          <FontIcon x:Name="ThemeIcon" Glyph="&#xE706;" />
        </Button>

        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup>
            <VisualState x:Name="CompactTitleBar">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="0" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="BrandText.Visibility" Value="Collapsed" />
                <Setter Target="PathLabel.Visibility" Value="Collapsed" />
                <Setter Target="SteamLabel.Visibility" Value="Collapsed" />
                <Setter Target="SmapiLabel.Visibility" Value="Collapsed" />
                <Setter Target="ProcessBadge.Visibility" Value="Collapsed" />
              </VisualState.Setters>
            </VisualState>
            <VisualState x:Name="RegularTitleBar">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="980" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="BrandText.Visibility" Value="Visible" />
                <Setter Target="PathLabel.Visibility" Value="Visible" />
                <Setter Target="SteamLabel.Visibility" Value="Visible" />
                <Setter Target="SmapiLabel.Visibility" Value="Visible" />
              </VisualState.Setters>
            </VisualState>
            <VisualState x:Name="WideTitleBar">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="1180" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="BrandText.Visibility" Value="Visible" />
                <Setter Target="PathLabel.Visibility" Value="Visible" />
                <Setter Target="SteamLabel.Visibility" Value="Visible" />
                <Setter Target="SmapiLabel.Visibility" Value="Visible" />
                <Setter Target="ProcessBadge.Visibility" Value="Visible" />
              </VisualState.Setters>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
      </Grid>
    </Border>

    <NavigationView x:Name="RootNavigation"
                    Grid.Row="1"
                    AllowDrop="True"
                    AlwaysShowHeader="False"
                    CompactPaneLength="48"
                    DragOver="OnRootDragOver"
                    Drop="OnRootDrop"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="True"
                    IsSettingsVisible="False"
                    IsTitleBarAutoPaddingEnabled="False"
                    OpenPaneLength="218"
                    PaneDisplayMode="Auto"
                    SelectionChanged="OnNavigationSelectionChanged">
      <NavigationView.MenuItems>
        <NavigationViewItem x:Name="OverviewNavigationItem" Content="概览" Tag="overview">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="我的 Mod" Tag="mods">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE90F;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="下载中心" Tag="downloads">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE896;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="分享大厅" Tag="share">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE72D;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="SMAPI" Tag="smapi">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE72E;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>
      <NavigationView.FooterMenuItems>
        <NavigationViewItem Content="设置" Tag="settings">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.FooterMenuItems>
      <NavigationView.PaneFooter>
        <StackPanel Margin="12,8,12,12" Orientation="Horizontal" Spacing="8">
          <Ellipse Width="7" Height="7" Fill="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
          <TextBlock Text="本地服务正常" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
      </NavigationView.PaneFooter>
      <Frame x:Name="ContentFrame"
             AllowDrop="True"
             DragOver="OnRootDragOver"
             Drop="OnRootDrop" />
    </NavigationView>

    <ProgressBar x:Name="BusyProgressBar"
                 Grid.Row="1"
                 Height="3"
                 VerticalAlignment="Top"
                 IsIndeterminate="True"
                 Visibility="Collapsed" />

    <InfoBar x:Name="GlobalInfoBar"
             Grid.Row="1"
             Margin="24"
             MaxWidth="460"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             IsClosable="True"
             IsOpen="False" />
  </Grid>
</Window>
