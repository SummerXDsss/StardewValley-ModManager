<Page
    x:Class="ValleySteward.WinUI.Pages.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

  <Grid Padding="32,26,32,32"
        RowSpacing="16"
        AllowDrop="True"
        DragOver="OnArchiveDragOver"
        Drop="OnArchiveDrop">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid ColumnSpacing="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock FontFamily="Segoe UI Variable Display" FontSize="28"
                   FontWeight="SemiBold" Text="下载中心" />
        <TextBlock Margin="0,5,0,0"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Nexus Mods 与 GitHub 实时结果" />
      </StackPanel>
      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Click="OnLocalArchiveClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE8E5;" />
            <TextBlock Text="安装本地 ZIP" />
          </StackPanel>
        </Button>
        <Button Click="OnNxmLinkClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE71B;" />
            <TextBlock Text="粘贴 NXM 链接" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1" ColumnSpacing="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="160" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBox x:Name="SearchBox"
               PlaceholderText="搜索名称、简介、作者或上传者"
               KeyDown="OnSearchKeyDown" />
      <ComboBox x:Name="SourceComboBox" Grid.Column="1" SelectedIndex="0">
        <ComboBoxItem Content="全部来源" />
        <ComboBoxItem Content="Nexus Mods" />
        <ComboBoxItem Content="GitHub" />
      </ComboBox>
      <Button x:Name="SearchButton" Grid.Column="2"
              Click="OnSearchClick" MinWidth="96">
        <StackPanel Orientation="Horizontal" Spacing="7">
          <FontIcon Glyph="&#xE721;" />
          <TextBlock Text="搜索" />
        </StackPanel>
      </Button>
    </Grid>

    <StackPanel Grid.Row="2" Spacing="8">
      <InfoBar x:Name="SearchInfoBar"
               IsOpen="False" IsClosable="True" />
      <InfoBar x:Name="TranslationInfoBar"
               IsOpen="False" IsClosable="True" />
    </StackPanel>

    <Grid Grid.Row="3">
      <ListView x:Name="ResultsList" SelectionMode="None">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <Border Padding="15,13" CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
              <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="130" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="64" Height="64"
                        CornerRadius="6"
                        VerticalAlignment="Top"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1">
                  <Grid>
                    <FontIcon FontSize="26"
                              Glyph="&#xE8B7;"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Image Width="62" Height="62"
                           Stretch="UniformToFill"
                           Loaded="OnRemoteCoverLoaded"
                           DataContextChanged="OnRemoteCoverDataContextChanged"
                           ImageFailed="OnRemoteCoverFailed"
                           AutomationProperties.Name="Mod 封面" />
                  </Grid>
                </Border>
                <StackPanel Grid.Column="1" Spacing="5">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                    <Border Padding="5,1" CornerRadius="3"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                      <TextBlock FontSize="11" Text="{Binding Source}" />
                    </Border>
                  </StackPanel>
                  <TextBlock FontSize="12"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{Binding Author}" /><Run Text=" · " />
                    <Run Text="{Binding Version}" /><Run Text=" · " />
                    <Run Text="{Binding Popularity}" />
                  </TextBlock>
                  <StackPanel>
                    <TextBlock MaxLines="2"
                               Text="{Binding Summary}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="WrapWholeWords"
                               Loaded="OnRemoteSummaryLoaded"
                               SizeChanged="OnRemoteSummarySizeChanged" />
                    <Grid ColumnSpacing="10" HorizontalAlignment="Left">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <Button Padding="0,2" HorizontalAlignment="Left"
                              Background="Transparent" BorderThickness="0"
                              Content="展开"
                              Visibility="Collapsed"
                              Loaded="OnSummaryToggleLoaded"
                              Click="OnToggleDescription" />
                      <Button Grid.Column="1" Padding="0,2"
                              HorizontalAlignment="Left"
                              Background="Transparent" BorderThickness="0"
                              IsEnabled="{Binding CanTranslate}"
                              Content="{Binding TranslationActionText}"
                              Click="OnTranslateClick" />
                    </Grid>
                  </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{Binding UpdatedText}" />
                <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="7">
                  <Button MinWidth="132"
                          Style="{StaticResource AccentButtonStyle}"
                          IsEnabled="{Binding CanQuickInstall}"
                          Click="OnQuickInstallClick"
                          ToolTipService.ToolTip="下载、检查并安装唯一可信的 Mod ZIP">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE896;" />
                      <TextBlock Text="{Binding QuickInstallActionText}" />
                    </StackPanel>
                  </Button>
                  <Button Click="OnNexusFilesClick"
                          Loaded="OnNexusFilesButtonLoaded"
                          ToolTipService.ToolTip="读取 Nexus 文件和版本">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE8B7;" />
                      <TextBlock Text="文件" />
                    </StackPanel>
                  </Button>
                  <Button Click="OnRemoteDetailsClick" ToolTipService.ToolTip="在应用内查看详情">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE946;" />
                      <TextBlock Text="详情" />
                    </StackPanel>
                  </Button>
                  <Button Click="OnOpenPageClick" ToolTipService.ToolTip="打开上游页面">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE8A7;" />
                      <TextBlock Text="上游" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <ProgressRing x:Name="SearchProgressRing"
                    Width="34" Height="34"
                    IsActive="False"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

      <Border x:Name="NexusDetailsPane"
              Width="540"
              HorizontalAlignment="Right"
              Visibility="Collapsed"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="1,0,0,0">
        <Grid Padding="22,18,22,22" RowSpacing="14">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
              <TextBlock x:Name="NexusDetailsTitle"
                         FontSize="20" FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock x:Name="NexusDetailsSubtitle"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button x:Name="CloseNexusDetailsButton"
                    Grid.Column="1"
                    Width="36" Height="36" Padding="0"
                    Click="OnCloseNexusDetailsClick"
                    ToolTipService.ToolTip="关闭文件面板">
              <FontIcon Glyph="&#xE711;" />
            </Button>
          </Grid>

          <InfoBar x:Name="DownloadInfoBar"
                   Grid.Row="1"
                   IsOpen="False"
                   IsClosable="True" />

          <StackPanel Grid.Row="2"
                      Orientation="Horizontal"
                      Spacing="8">
            <Button x:Name="InstallDownloadedFileButton"
                    Visibility="Collapsed"
                    Click="OnInstallDownloadedFileClick">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE896;" />
                <TextBlock Text="安装到 Mods" />
              </StackPanel>
            </Button>
            <Button x:Name="OpenDownloadedFileButton"
                    Visibility="Collapsed"
                    Click="OnOpenDownloadedFileClick">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE838;" />
                <TextBlock Text="在文件夹中显示" />
              </StackPanel>
            </Button>
            <Button x:Name="OpenNexusFilePageButton"
                    Visibility="Collapsed"
                    Click="OnOpenNexusFilePageClick">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE8A7;" />
                <TextBlock Text="打开文件页" />
              </StackPanel>
            </Button>
          </StackPanel>

          <Grid x:Name="DownloadProgressPanel"
                Grid.Row="3"
                Visibility="Collapsed"
                ColumnSpacing="10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
              <TextBlock x:Name="DownloadStatusText"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         Text="正在准备下载…" />
              <ProgressBar x:Name="DownloadProgressBar"
                           Minimum="0" Maximum="100"
                           IsIndeterminate="True" />
            </StackPanel>
            <Button x:Name="CancelDownloadButton"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Click="OnCancelDownloadClick"
                    Content="取消" />
          </Grid>

          <Grid Grid.Row="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <ItemsControl x:Name="NexusFilesList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="14"
                            CornerRadius="6"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                      <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel Spacing="2">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding Name}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                              <Run Text="{Binding LastUploadedText}" /><Run Text=" · " />
                              <Run Text="{Binding VersionsSummary}" />
                            </TextBlock>
                          </StackPanel>
                          <Border Grid.Column="1"
                                  Padding="6,2"
                                  CornerRadius="3"
                                  VerticalAlignment="Top"
                                  Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock FontSize="11" Text="{Binding StatusText}" />
                          </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Versions}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid Padding="0,8,0,8" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                  <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                               Text="{Binding PrimaryText}" />
                                  </StackPanel>
                                  <TextBlock FontSize="12"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding VersionText}" /><Run Text=" · " />
                                    <Run Text="{Binding CategoryText}" /><Run Text=" · " />
                                    <Run Text="{Binding UploadedText}" />
                                  </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnDownloadVersionClick"
                                        ToolTipService.ToolTip="下载后检查并安装">
                                  <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE896;" />
                                    <TextBlock Text="下载并安装" />
                                  </StackPanel>
                                </Button>
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <ProgressRing x:Name="NexusDetailsProgressRing"
                          Width="36" Height="36"
                          IsActive="False"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Page>
