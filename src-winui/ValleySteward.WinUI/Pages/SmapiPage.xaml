<Page
    x:Class="ValleySteward.WinUI.Pages.SmapiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="1100" Padding="32,26,32,48"
                HorizontalAlignment="Stretch" Spacing="20">
      <Grid>
        <StackPanel>
          <TextBlock FontFamily="Segoe UI Variable Display" FontSize="28"
                     FontWeight="SemiBold" Text="SMAPI" />
          <TextBlock Margin="0,5,0,0"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="安装、更新或卸载官方 SMAPI 运行环境" />
        </StackPanel>
        <Button x:Name="RefreshButton"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Click="OnRefreshClick" ToolTipService.ToolTip="重新检测">
          <FontIcon Glyph="&#xE72C;" />
        </Button>
      </Grid>

      <InfoBar x:Name="SmapiInfoBar" IsOpen="False" IsClosable="True" />

      <Border Padding="20" CornerRadius="6"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1">
        <Grid RowSpacing="16" ColumnSpacing="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock MinWidth="120"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="本机状态" />
          <TextBlock Grid.Column="1" FontWeight="SemiBold"
                     Text="{Binding SmapiStatusText}" />
          <TextBlock Grid.Row="1"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="本机版本" />
          <TextBlock x:Name="InstalledVersionText" Grid.Row="1" Grid.Column="1" />
          <TextBlock Grid.Row="2"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="入口文件" />
          <TextBlock x:Name="ExecutableText" Grid.Row="2" Grid.Column="1" />
          <TextBlock Grid.Row="3"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="游戏目录" />
          <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GamePathText}"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
      </Border>

      <Border Padding="20" CornerRadius="6"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1">
        <Grid RowSpacing="16" ColumnSpacing="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock MinWidth="120"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="官方稳定版" />
          <TextBlock x:Name="LatestVersionText" Grid.Column="1"
                     FontWeight="SemiBold" Text="正在检查…" />
          <TextBlock Grid.Row="1"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="更新状态" />
          <TextBlock x:Name="UpdateStatusText" Grid.Row="1" Grid.Column="1"
                     Text="尚未检查" />
          <TextBlock Grid.Row="2"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="Release 来源" />
          <TextBlock x:Name="ReleaseSourceText" Grid.Row="2" Grid.Column="1"
                     Text="GitHub" />
          <TextBlock Grid.Row="3"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="完整性校验" />
          <TextBlock x:Name="DigestStatusText" Grid.Row="3" Grid.Column="1"
                     Text="等待 Release 元数据" TextWrapping="Wrap" />
        </Grid>
      </Border>

      <StackPanel x:Name="OperationPanel" Spacing="8" Visibility="Collapsed">
        <Grid ColumnSpacing="12">
          <TextBlock x:Name="OperationStatusText" VerticalAlignment="Center"
                     FontWeight="SemiBold" Text="正在准备…" />
          <TextBlock x:Name="OperationPercentText" HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
        <ProgressBar x:Name="OperationProgressBar" Minimum="0" Maximum="100"
                     IsIndeterminate="True" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="InstallButton" Style="{StaticResource AccentButtonStyle}"
                Click="OnInstallClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE896;" />
            <TextBlock x:Name="InstallButtonText" Text="安装 SMAPI" />
          </StackPanel>
        </Button>
        <Button x:Name="UninstallButton" Click="OnUninstallClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE74D;" />
            <TextBlock Text="卸载 SMAPI" />
          </StackPanel>
        </Button>
        <Button x:Name="LaunchSmapiButton" Click="OnLaunchClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE768;" />
            <TextBlock Text="启动 SMAPI" />
          </StackPanel>
        </Button>
        <Button x:Name="CheckReleaseButton" Click="OnCheckReleaseClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE895;" />
            <TextBlock Text="检查更新" />
          </StackPanel>
        </Button>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Click="OnOpenReleaseClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE8A7;" />
            <TextBlock Text="GitHub Release" />
          </StackPanel>
        </Button>
        <Button Click="OnOpenOfficialClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE774;" />
            <TextBlock Text="SMAPI 官网" />
          </StackPanel>
        </Button>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Page>
