<Page
    x:Class="ValleySteward.WinUI.Pages.ShareHallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

  <Grid Padding="32,26,32,32" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid ColumnSpacing="16" RowSpacing="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock FontFamily="Segoe UI Variable Display"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Text="分享大厅" />
        <TextBlock x:Name="EndpointText"
                   Margin="0,5,0,0"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
      </StackPanel>
      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button x:Name="HallButton" Click="OnShowHallClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE80F;" />
            <TextBlock Text="大厅" />
          </StackPanel>
        </Button>
        <Button x:Name="MySharesButton" Click="OnShowMySharesClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE77B;" />
            <TextBlock Text="我的分享" />
          </StackPanel>
        </Button>
        <Button x:Name="ClaimButton" Click="OnClaimMySharesClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE8D4;" />
            <TextBlock Text="IP 认领" />
          </StackPanel>
        </Button>
        <Button x:Name="PublishButton" Click="OnPublishClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE72D;" />
            <TextBlock Text="分享我的列表" />
          </StackPanel>
        </Button>
        <Button x:Name="RefreshButton" Click="OnRefreshClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE72C;" />
            <TextBlock Text="刷新" />
          </StackPanel>
        </Button>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <TextBox x:Name="SearchBox"
                 Width="220"
                 PlaceholderText="搜索用户、IP、Mod"
                 KeyDown="OnSearchKeyDown" />
        <Button x:Name="SearchButton" Click="OnSearchClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE721;" />
            <TextBlock Text="搜索" />
          </StackPanel>
        </Button>
        <CheckBox x:Name="IncludeSearchOnlyBox"
                  VerticalAlignment="Center"
                  Content="包含仅搜索可见" />
        <TextBox x:Name="ShareCodeBox"
                 Width="132"
                 MaxLength="10"
                 PlaceholderText="分享码"
                 KeyDown="OnShareCodeKeyDown" />
        <Button x:Name="FindCodeButton" Click="OnFindCodeClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE721;" />
            <TextBlock Text="打开" />
          </StackPanel>
        </Button>
        <Button x:Name="CopyCodeButton" Click="OnCopyCodeClick">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <FontIcon Glyph="&#xE8C8;" />
            <TextBlock Text="复制" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

    <InfoBar x:Name="ShareInfoBar"
             Grid.Row="1"
             IsOpen="False"
             IsClosable="True" />

    <Grid Grid.Row="2">
      <ListView x:Name="ShareList"
                SelectionMode="None">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <Border Padding="16,14"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
              <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="9">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding HeaderText}"
                               TextTrimming="CharacterEllipsis" />
                    <Border Padding="6,2"
                            CornerRadius="3"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                      <TextBlock FontSize="12" Text="{Binding Code}" />
                    </Border>
                  </StackPanel>
                  <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                             Text="{Binding SummaryText}" />

                  <Grid MinHeight="46">
                    <ItemsControl ItemsSource="{Binding CoverTiles}"
                                  HorizontalAlignment="Left">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Width="44"
                                  Height="44"
                                  Margin="0,0,6,0"
                                  CornerRadius="5"
                                  Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  ToolTipService.ToolTip="{Binding ToolTip}">
                            <Grid>
                              <TextBlock Text="{Binding Initial}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                              <Image Width="42"
                                     Height="42"
                                     Stretch="UniformToFill"
                                     Loaded="OnShareCoverLoaded"
                                     DataContextChanged="OnShareCoverDataContextChanged"
                                     ImageFailed="OnShareCoverFailed"
                                     AutomationProperties.Name="共享 Mod 封面" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="OnDetailsClick">
                  <StackPanel Orientation="Horizontal" Spacing="7">
                    <FontIcon Glyph="&#xE946;" />
                    <TextBlock Text="详情" />
                  </StackPanel>
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <Grid x:Name="MySharesPanel"
            Visibility="Collapsed"
            RowSpacing="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="同 IP 发布或认领的分享可以在这里修改可见性、复制分享码或删除。"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <ListView x:Name="MyShareList"
                  Grid.Row="1"
                  SelectionMode="None">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border Padding="16,14"
                      CornerRadius="6"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">
                <StackPanel Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding HeaderText}"
                               TextTrimming="CharacterEllipsis" />
                    <Border Padding="6,2"
                            CornerRadius="3"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                      <TextBlock FontSize="12" Text="{Binding Code}" />
                    </Border>
                    <Border Padding="6,2"
                            CornerRadius="3"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                      <TextBlock FontSize="12" Text="{Binding DisplayVisibilityText}" />
                    </Border>
                  </StackPanel>
                  <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                             Text="{Binding SummaryText}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnDetailsClick">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE946;" />
                        <TextBlock Text="详情" />
                      </StackPanel>
                    </Button>
                    <Button Click="OnCopyEntryCodeClick">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE8C8;" />
                        <TextBlock Text="复制分享码" />
                      </StackPanel>
                    </Button>
                    <Button Click="OnToggleMyShareVisibilityClick"
                            Content="{Binding VisibilityToggleText}" />
                    <Button Click="OnDeleteMyShareClick">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE74D;" />
                        <TextBlock Text="删除" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Grid>
  </Grid>
</Page>
